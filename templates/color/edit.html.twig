{% extends 'base.html.twig' %}

{% block title %}Edit Color{% endblock %}

{% block body %}

    <div class="container" style="display: flex;flex-direction: column;align-items: center;justify-content: center;">
        <h1>Edit Tag</h1>
        {% set errorFlashes = app.flashes('error') %}
        {% if errorFlashes is not empty %}
            <div class="alert alert-danger">
                <ul class="mb-0">
                    {% for error in errorFlashes %}
                        {% for field, messages in error %}
                            {% for message in messages %}
                                <li><strong>{{ field }}</strong>: {{ message }}</li>
                            {% endfor %}
                        {% endfor %}
                    {% endfor %}
                </ul>
            </div>
        {% endif %}
        <form action="{{ path('app_color_update', { id: color.id }) }}" method="post" style="width: 500px;">
            <div class="form-group">
                <label for="name">Name</label>
                <input type="text" name="name" id="name" class="form-control" value="{{ color.name }}">
            </div>
            <div class="form-group">
                <label for="code">Code</label>
                <input type="text" name="code" id="code" class="form-control" value="{{ color.code }}">
            </div>
            <button type="submit" class="btn btn-primary">Update</button>
        </form>
    </div>
{% endblock %}
