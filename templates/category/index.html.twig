{% extends 'base.html.twig' %}

{% block title %}Hello CategoryController!{% endblock %}

{% block body %}
<div class="container">
    <h1>Categories</h1>
    <a href="{{ path('app_category_create') }}" class="btn btn-primary">Create Category</a>
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for category in categories %}
                <tr>
                    <td>{{ category.name | capitalize }}</td>
                    <td>{{ category.description | capitalize }}</td>
                    <td>
                        <a href="{{ path('app_category_edit', { id: category.id }) }}" class="btn btn-success">Edit</a>
                        <a class="btn btn-danger">Delete</a>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
