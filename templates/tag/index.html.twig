{% extends 'base.html.twig' %}

{% block title %}Hello TagController!{% endblock %}

{% block body %}
    <div class="container">
        <h1>Tags</h1>
        <a href="{{ path('app_tag_create') }}" class="btn btn-primary">Create Tag</a>
        {% set errorFlashes = app.flashes('error') %}
        {% if errorFlashes is not empty %}
            <div class="alert alert-danger">
                <ul class="mb-0">
                    {% for error in errorFlashes %}
                        <li>{{ error }}</li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}
        <table class="table">
            <thead>
            <tr>
                <th>Name</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for tag in tags %}
                <tr>
                    <td>{{ tag.name | capitalize }}</td>
                    <td>
                        <a href="{{ path('app_tag_edit', { id: tag.id }) }}" class="btn btn-success">Edit</a>
                        <form method="post"
                              action="{{ path('app_tag_delete', { id: tag.id }) }}"
                              >
                            <input type="hidden" name="_method" value="DELETE">
                            <button type="submit" class="btn btn-danger">
                                Delete
                            </button>
                        </form>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
